{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"outDir": "./dist/",
		"sourceMap": true,
		"noImplicitAny": true,
		"module": "es6",
		"target": "es6",
		"allowJs": true,
		"moduleResolution": "node",
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"lib": [ "ES2020", "DOM" ],
		"strict": true
	}
}